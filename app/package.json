{
  "name": "trade-gateway",
  "version": "1.0.0",
  "description": "TradingView からの webhook を受けて、実際にブローカーに対して発注を行う web api を提供するアプリケーション。",
  "main": "dist/index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/*.test.ts src/**/*.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/iszk/trade-gateway.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/iszk/trade-gateway/issues"
  },
  "homepage": "https://github.com/iszk/trade-gateway#readme",
  "dependencies": {
    "@google-cloud/pino-logging-gcp-config": "^1.3.3",
    "@hono/node-server": "^1.19.11",
    "hono": "^4.12.8",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
